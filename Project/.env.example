# Django Settings
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave DB_HOST empty to use SQLite locally.
DB_NAME=smart_bookstore
DB_USER=bookstore
DB_PASSWORD=bookstore
DB_HOST=
DB_PORT=5432

# AI / Ollama Settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=60
OLLAMA_CONTEXT_TURNS=6
OLLAMA_MAX_TOKENS=256
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=2048
CHATBOT_RATE_LIMIT_REQUESTS=20
CHATBOT_RATE_LIMIT_WINDOW=60
REGISTER_RATE_LIMIT_REQUESTS=5
REGISTER_RATE_LIMIT_WINDOW=300
COUPON_RATE_LIMIT_REQUESTS=10
COUPON_RATE_LIMIT_WINDOW=60
CHECKOUT_RATE_LIMIT_REQUESTS=5
CHECKOUT_RATE_LIMIT_WINDOW=300

# VNPay Sandbox
VNP_TMN_CODE=your-tmn-code
VNP_HASH_KEY=your-hash-key
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Production Security (Values to use when deploying - DEBUG=False)
# Note: For production, SECRET_KEY must be a unique, secret random string.
# ALLOWED_HOSTS must contain your production domain name.
SECURE_SSL_REDIRECT=False # Set to True on production (forces HTTPS)
SESSION_COOKIE_SECURE=False # Set to True on production
CSRF_COOKIE_SECURE=False # Set to True on production
SECURE_HSTS_SECONDS=0 # Set to 31536000 (1 year) on production
CSRF_TRUSTED_ORIGINS=https://yourdomain.com # Add your domain here

# Login Lockout & Security
LOGIN_RATE_LIMIT_FAILED_ATTEMPTS=5
LOGIN_RATE_LIMIT_LOCKOUT_WINDOW=900

# Email Configuration
# In development (DEBUG=True), emails are printed to the console by default.
# For production, configure a real SMTP server:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Bookie <noreply@bookie.vn>

# Low stock alert
LOW_STOCK_THRESHOLD=10

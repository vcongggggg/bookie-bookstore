# ============================================
# Bookie Bookstore - Environment Configuration
# ============================================
# Copy this file to .env and update the values.
# NEVER commit .env to version control!

# ---- Django Core ----
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Environment selector: 'development' or 'production'
# Controls which settings module is loaded (settings/local.py or settings/production.py)
DJANGO_ENV=development

# ---- Database ----
# Leave DB_HOST empty to use SQLite locally (development mode).
# Set DB_HOST to use PostgreSQL (required for production/docker).
DB_NAME=bookstore_db
DB_USER=bookstore
DB_PASSWORD=bookstore
DB_HOST=
DB_PORT=5432
# Alternative: use a single DATABASE_URL instead of individual DB_* vars:
# DATABASE_URL=postgres://bookstore:bookstore@db:5432/bookstore_db

# ---- Redis (Production / Docker) ----
# Used for Django cache backend and Huey task broker.
# Not required for local development (SQLite is used instead).
REDIS_URL=redis://redis:6379/0

# ---- AI / Ollama Chatbot ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT=60
OLLAMA_CONTEXT_TURNS=6
OLLAMA_MAX_TOKENS=256
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_CTX=2048

# ---- Rate Limiting ----
CHATBOT_RATE_LIMIT_REQUESTS=20
CHATBOT_RATE_LIMIT_WINDOW=60
REGISTER_RATE_LIMIT_REQUESTS=5
REGISTER_RATE_LIMIT_WINDOW=300
COUPON_RATE_LIMIT_REQUESTS=10
COUPON_RATE_LIMIT_WINDOW=60
CHECKOUT_RATE_LIMIT_REQUESTS=5
CHECKOUT_RATE_LIMIT_WINDOW=300
LOGIN_RATE_LIMIT_FAILED_ATTEMPTS=5
LOGIN_RATE_LIMIT_LOCKOUT_WINDOW=900

# ---- VNPay Sandbox ----
VNP_TMN_CODE=your-tmn-code
VNP_HASH_KEY=your-hash-key
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# ---- Production Security ----
# Set these values when deploying with DEBUG=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ---- Email Configuration ----
# In development (DEBUG=True), emails are printed to the console by default.
# For production, configure a real SMTP server:
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Bookie <noreply@bookie.vn>

# ---- Low Stock Alert ----
LOW_STOCK_THRESHOLD=10
